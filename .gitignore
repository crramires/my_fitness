# ---------------------------------------------
# 📦 Bundler & Rails-specific
# ---------------------------------------------
.bundle
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep
/public/assets
/config/master.key

# ---------------------------------------------
# 💻 Environment & Credentials
# ---------------------------------------------
.env*
*.key

# ---------------------------------------------
# 📚 Database (SQLite - se usar em dev)
# ---------------------------------------------
db/*.sqlite3
db/*.sqlite3-journal

# ---------------------------------------------
# 🧪 Testing & Coverage
# ---------------------------------------------
coverage/
.byebug_history

# ---------------------------------------------
# 🧰 Node & JS tooling (se usar importmap, yarn, etc)
# ---------------------------------------------
node_modules/
yarn-error.log
npm-debug.log

# ---------------------------------------------
# 🧠 IDEs & Editors
# ---------------------------------------------
.vscode/
*.swp

# ---------------------------------------------
# 🖥️ Sistema operacional
# ---------------------------------------------
.DS_Store
Thumbs.db
